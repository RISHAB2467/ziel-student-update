rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // This project currently uses app-level localStorage login (no Firebase Auth tokens).
    // Keep access scoped to known app collections and deny unknown paths by default.
    function isAppAllowed() {
      return true;
    }

    // Teacher Collection Rules
    match /teachers/{teacherId} {
      allow read, write: if isAppAllowed();
    }

    // Student Collection Rules
    match /students/{studentId} {
      allow read, write: if isAppAllowed();

      match /payments/{paymentId} {
        allow read, write: if isAppAllowed();
      }
    }

    // Rules for entries
    match /entries/{entryId} {
      allow read, write: if isAppAllowed();
    }

    // Rules for doubt sessions
    match /doubt_sessions/{sessionId} {
      allow read, write: if isAppAllowed();
    }

    // Rules for settings used by app logic
    match /settings/{settingId} {
      allow read, write: if isAppAllowed();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
